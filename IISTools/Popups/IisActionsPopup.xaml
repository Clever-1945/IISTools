<UserControl
    x:Class="IISTools.Popups.IisActionsPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:IISTools.Popups"
    xmlns:controls="clr-namespace:IISTools.Controls"
    xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d" 
    d:DesignHeight="450" 
    d:DesignWidth="800">
    <Grid Background="Transparent">
        <Border 
            Margin="0 0 20 20" 
            Background="#323232"
            CornerRadius="5">
            <Border.Effect>
                <DropShadowEffect 
                    BlurRadius="15" 
                    ShadowDepth="5" 
                    Direction="270" 
                    Opacity="0.4" 
                    Color="Black" />
            </Border.Effect>

            <Grid>
                <controls:IisActionsControl />
            </Grid>
        </Border>
    </Grid>
</UserControl>
