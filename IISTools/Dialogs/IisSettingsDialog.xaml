<Window 
    x:Class="IISTools.Dialogs.IisSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:local="clr-namespace:IISTools.Dialogs"
    mc:Ignorable="d"
    Background="#323232"
    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
    WindowStyle="ToolWindow" 
    WindowStartupLocation="Manual"
    ResizeMode="NoResize"
    SizeToContent="Height"
    Title="Настройки плагина" 
    ShowInTaskbar="False"
    Height="Auto" 
    Width="550">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.DockTargetButtonBackgroundBeginKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.DockTargetButtonBorderKey}}"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="15, 0, 15, 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border 
                        Padding="{TemplateBinding Padding}"
                        Background="{DynamicResource {x:Static vsshell:VsBrushes.DockTargetButtonBackgroundBeginKey}}" 
                        BorderBrush="#6A6287" 
                        BorderThickness="1" 
                        CornerRadius="3">
                            <ContentPresenter 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="150" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="90" />
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="0" Click="OnAddPing">Добаить</Button>
        <Button Grid.Row="0" Grid.Column="1" Click="OnDeletePing">Удалить</Button>

        <DataGrid 
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="5"
            HeadersVisibility="Column"
            RowHeaderWidth="0"
            Name="_dataGridPings" 
            AutoGenerateColumns="False" 
            CanUserAddRows="False"
            Background="#1E1E1E" 
            SelectionMode="Single"
            SelectionChanged="OnSelectedPing">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#323232" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Padding" Value="10,0,0,0" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="BorderBrush" Value="#3F3F46" />
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#1E1E1E" />
                    <Setter Property="Foreground" Value="#F1F1F1" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2B2B2C" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3F3F46" />
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Foreground" Value="#F1F1F1" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя пинга" Binding="{Binding Name}" Width="250" />
                <DataGridTextColumn Header="Url" Binding="{Binding Url}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Grid.Column="3" Click="OnCancel">Отмена</Button>
        <Button Grid.Row="3" Grid.Column="4" Click="OnOk">Ok</Button>
    </Grid>
</Window>
